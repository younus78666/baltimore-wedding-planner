---
const year = new Date().getFullYear();
---

<footer class="bg-stone-950 text-stone-400 pt-16 md:pt-20 pb-10 border-t border-stone-900">
  <div class="max-w-site mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Main footer grid -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-12 pb-14 border-b border-stone-900/60">

      <!-- Brand column -->
      <div class="md:col-span-4 space-y-5">
        <div class="flex items-center gap-2.5">
          <div class="w-9 h-9 bg-[#C89481]/15 rounded-xl border border-[#C89481]/25 flex items-center justify-center flex-shrink-0">
            <svg class="w-4.5 h-4.5 text-[#C89481] fill-current" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
            </svg>
          </div>
          <div>
            <p class="font-display font-bold text-white text-base leading-tight">Baltimore Wedding Planner</p>
            <p class="font-serif italic text-[#C89481]/80 text-[10.5px] mt-0.5">Maryland Budget Wedding Studio</p>
          </div>
        </div>
        <p class="text-stone-500 text-xs font-body leading-relaxed max-w-xs">
          Budget-friendly wedding planning for couples across Maryland. John creates beautiful, stress-free weddings for budgets under $20,000 — full-service, day-of coordination, and elopements.
        </p>
        <a href="/contact" class="btn-primary text-xs px-5 py-2.5 inline-flex">
          Book Free Consultation
        </a>
      </div>

      <!-- Services column -->
      <div class="md:col-span-3">
        <h2 class="font-display text-xs font-bold uppercase tracking-widest text-stone-500 mb-5">Services</h2>
        <ul class="space-y-3">
          <li><a href="/services/full-service-wedding-planning" class="text-xs font-body text-stone-400 hover:text-[#C89481] transition-colors">Full-Service Planning</a></li>
          <li><a href="/services/day-of-wedding-coordinator" class="text-xs font-body text-stone-400 hover:text-[#C89481] transition-colors">Day-of Coordination</a></li>
          <li><a href="/services/partial-wedding-planning" class="text-xs font-body text-stone-400 hover:text-[#C89481] transition-colors">Partial Planning</a></li>
          <li><a href="/services/elopement-planner-maryland" class="text-xs font-body text-stone-400 hover:text-[#C89481] transition-colors">Elopement Planning</a></li>
          <li><a href="/wedding-planning-packages" class="text-xs font-body text-stone-400 hover:text-[#C89481] transition-colors">Packages and Pricing</a></li>
        </ul>

        <h2 class="font-display text-xs font-bold uppercase tracking-widest text-stone-500 mb-4 mt-8">Resources</h2>
        <ul class="space-y-3">
          <li><a href="/blog" class="text-xs font-body text-stone-400 hover:text-[#C89481] transition-colors">Wedding Guides</a></li>
          <li><a href="/faq" class="text-xs font-body text-stone-400 hover:text-[#C89481] transition-colors">FAQ</a></li>
          <li><a href="/blog/baltimore-wedding-venues" class="text-xs font-body text-stone-400 hover:text-[#C89481] transition-colors">Baltimore Venues</a></li>
          <li><a href="/blog/wedding-venues-in-maryland" class="text-xs font-body text-stone-400 hover:text-[#C89481] transition-colors">Maryland Venues</a></li>
        </ul>
      </div>

      <!-- Areas column -->
      <div class="md:col-span-2">
        <h2 class="font-display text-xs font-bold uppercase tracking-widest text-stone-500 mb-5">Service Areas</h2>
        <ul class="space-y-3">
          <li><a href="/locations/annapolis-wedding-planner" class="text-xs font-body text-stone-400 hover:text-[#C89481] transition-colors">Annapolis, MD</a></li>
          <li><a href="/locations/columbia-md-wedding-planner" class="text-xs font-body text-stone-400 hover:text-[#C89481] transition-colors">Columbia, MD</a></li>
          <li><a href="/locations/towson-wedding-planner" class="text-xs font-body text-stone-400 hover:text-[#C89481] transition-colors">Towson, MD</a></li>
          <li><a href="/locations/frederick-wedding-planner" class="text-xs font-body text-stone-400 hover:text-[#C89481] transition-colors">Frederick, MD</a></li>
          <li><a href="/locations/rockville-wedding-planner" class="text-xs font-body text-stone-400 hover:text-[#C89481] transition-colors">Rockville, MD</a></li>
          <li><a href="/locations" class="text-xs font-body text-[#C89481] hover:text-[#B5826F] transition-colors">All Areas →</a></li>
        </ul>
      </div>

      <!-- Contact column -->
      <div class="md:col-span-3">
        <h2 class="font-display text-xs font-bold uppercase tracking-widest text-stone-500 mb-5">Contact</h2>
        <ul class="space-y-3">
          <li>
            <a href="tel:+14105550100" class="flex items-center gap-2 text-xs font-body text-stone-400 hover:text-[#C89481] transition-colors">
              <svg class="w-3.5 h-3.5 text-[#C89481] flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              (410) 555-0100
            </a>
          </li>
          <li>
            <a href="mailto:john@baltimoreweddingplanner.com" class="flex items-center gap-2 text-xs font-body text-stone-400 hover:text-[#C89481] transition-colors">
              <svg class="w-3.5 h-3.5 text-[#C89481] flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              john@baltimoreweddingplanner.com
            </a>
          </li>
          <li>
            <span class="flex items-center gap-2 text-xs font-body text-stone-400">
              <svg class="w-3.5 h-3.5 text-[#C89481] flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              Baltimore, MD — All of Maryland
            </span>
          </li>
        </ul>

        <!-- Trust signals -->
        <div class="mt-7 space-y-2.5">
          <div class="flex items-center gap-2">
            <span class="text-amber-400 text-xs">★★★★★</span>
            <span class="text-xs font-body text-stone-500">5-Star Google Rating</span>
          </div>
          <div class="flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5 text-[#C89481]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            <span class="text-xs font-body text-stone-500">50+ Maryland Weddings</span>
          </div>
          <div class="flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5 text-[#C89481]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <span class="text-xs font-body text-stone-500">Budgets Under $20,000</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs font-body text-stone-600 text-center sm:text-left">
        &copy; {year} Baltimore Wedding Planner. Serving couples across Maryland. All rights reserved.
      </p>
      <div class="flex items-center gap-5">
        <a href="/privacy-policy" class="text-xs font-body text-stone-600 hover:text-[#C89481] transition-colors">Privacy Policy</a>
        <a href="/terms-of-service" class="text-xs font-body text-stone-600 hover:text-[#C89481] transition-colors">Terms</a>
        <a href="/cookie-policy" class="text-xs font-body text-stone-600 hover:text-[#C89481] transition-colors">Cookie Policy</a>
        <button onclick="window.resetCookieConsent?.()" class="text-xs font-body text-stone-600 hover:text-[#C89481] transition-colors cursor-pointer bg-transparent border-0 p-0" type="button">Cookie Preferences</button>
        <a href="/sitemap-index.xml" class="text-xs font-body text-stone-600 hover:text-[#C89481] transition-colors">Sitemap</a>
      </div>
    </div>
  </div>
</footer>
