---
const year = new Date().getFullYear();

// Blog posts for the popular guides section
const popularGuides = [
  { label: 'How to Get Married in MD', href: '/blog/how-to-get-married-in-maryland' },
  { label: 'Maryland Marriage License', href: '/blog/maryland-marriage-license' },
  { label: 'Average Wedding Cost MD', href: '/blog/average-wedding-cost-maryland' },
  { label: 'Baltimore Wedding Venues', href: '/blog/baltimore-wedding-venues' },
  { label: 'Maryland Wedding Venues', href: '/blog/wedding-venues-in-maryland' },
  { label: 'Wedding Planner Cost', href: '/blog/wedding-planner-cost-baltimore' },
];
---

<!-- Schema.org LocalBusiness for footer -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Baltimore Wedding Planner",
  "description": "Budget-friendly wedding planning for couples across Maryland. Full-service, day-of coordination, and elopement packages under $20,000.",
  "url": "https://baltimoreweddingplanner.com",
  "telephone": "(410) 555-0100",
  "email": "john@baltimoreweddingplanner.com",
  "areaServed": { "@type": "State", "name": "Maryland" },
  "priceRange": "$300-$3,000",
  "founder": { "@type": "Person", "name": "John" },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5.0",
    "reviewCount": "50+",
    "bestRating": "5"
  },
  "openingHours": "Mo-Fr 09:00-18:00",
  "sameAs": []
})} />
</script>

<footer class="relative bg-stone-950 text-stone-400 pt-20 pb-8 overflow-hidden" itemscope itemtype="https://schema.org/WPFooter">
  <!-- Ambient glow orbs -->
  <div class="absolute top-0 left-1/4 w-[600px] h-[600px] bg-[#C89481]/[0.03] rounded-full blur-[120px] pointer-events-none" aria-hidden="true"></div>
  <div class="absolute bottom-0 right-1/4 w-[400px] h-[400px] bg-[#8FAF98]/[0.025] rounded-full blur-[100px] pointer-events-none" aria-hidden="true"></div>

  <!-- Dot grid overlay -->
  <div class="absolute inset-0 opacity-[0.015] pointer-events-none" aria-hidden="true" style="background-image: radial-gradient(rgba(255,255,255,0.3) 1px, transparent 1px); background-size: 24px 24px;"></div>

  <div class="max-w-site mx-auto px-4 sm:px-6 lg:px-8 relative z-10">

    <!-- Newsletter + Brand top section -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 pb-14 border-b border-stone-900/60">

      <!-- Brand column -->
      <div class="lg:col-span-4 space-y-5">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-gradient-to-br from-[#C89481] to-[#B07965] rounded-xl flex items-center justify-center flex-shrink-0 shadow-lg shadow-[#C89481]/20">
            <svg class="w-5 h-5 text-white fill-current" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
            </svg>
          </div>
          <div>
            <p class="font-display font-bold text-white text-base leading-tight tracking-tight">Baltimore Wedding Planner</p>
            <p class="font-serif italic text-[#C89481]/70 text-[11px] mt-px">Maryland Budget Wedding Studio</p>
          </div>
        </div>
        <p class="text-stone-500 text-sm font-body leading-relaxed max-w-xs">
          Budget-friendly wedding planning for couples across Maryland. John creates beautiful, stress-free weddings for budgets under <span class="text-stone-300 font-medium">$20,000</span> — full-service, day-of coordination, and elopements.
        </p>
        <div class="flex items-center gap-3 pt-1">
          <a href="/contact" class="btn-primary text-xs px-5 py-2.5 inline-flex items-center gap-1.5 group">
            Book Free Consultation
            <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
          <a href="tel:+14105550100" class="text-xs font-body text-stone-500 hover:text-[#C89481] transition-colors flex items-center gap-1.5 py-2.5 px-4 rounded-lg border border-stone-800 hover:border-[#C89481]/30">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            Call Now
          </a>
        </div>

        <!-- Trust badges -->
        <div class="flex flex-wrap gap-3 pt-2">
          <span class="inline-flex items-center gap-1.5 text-[11px] font-body bg-stone-900/80 text-stone-400 px-3 py-1.5 rounded-full border border-stone-800">
            <svg class="w-3 h-3 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            5.0 ★ Google Rating
          </span>
          <span class="inline-flex items-center gap-1.5 text-[11px] font-body bg-stone-900/80 text-stone-400 px-3 py-1.5 rounded-full border border-stone-800">
            <svg class="w-3 h-3 text-[#C89481]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            50+ Weddings
          </span>
          <span class="inline-flex items-center gap-1.5 text-[11px] font-body bg-stone-900/80 text-stone-400 px-3 py-1.5 rounded-full border border-stone-800">
            <svg class="w-3 h-3 text-[#8FAF98]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            Budgets Under $20K
          </span>
        </div>
      </div>

      <!-- Newsletter signup -->
      <div class="lg:col-span-3">
        <div class="bg-stone-900/40 border border-stone-800/60 rounded-2xl p-6 backdrop-blur-sm">
          <h2 class="font-display text-xs font-bold uppercase tracking-widest text-stone-400 mb-1.5">Stay Inspired</h2>
          <p class="text-sm font-body text-stone-500 mb-4 leading-relaxed">Get Maryland wedding tips, venue updates, and budget advice straight to your inbox.</p>
          <form class="space-y-3" onsubmit="event.preventDefault(); alert('Thanks for subscribing! We\'ll be in touch.');">
            <div class="relative">
              <input type="email" placeholder="Your email address" required class="w-full bg-stone-900/60 border border-stone-700/60 rounded-xl px-4 py-3 text-sm text-white placeholder:text-stone-600 font-body focus:outline-none focus:ring-2 focus:ring-[#C89481]/40 focus:border-[#C89481]/50 transition-all" />
            </div>
            <button type="submit" class="w-full bg-gradient-to-r from-[#C89481] to-[#B07965] hover:from-[#BD806D] hover:to-[#A06A58] text-white text-xs font-bold font-display tracking-wide uppercase px-5 py-3 rounded-xl transition-all duration-200 shadow-lg shadow-[#C89481]/20 flex items-center justify-center gap-2 group">
              Subscribe
              <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
            </button>
          </form>
          <p class="text-[10px] font-body text-stone-600 mt-3">No spam. Unsubscribe anytime.</p>
        </div>
      </div>

      <!-- Quick Contact -->
      <div class="lg:col-span-2">
        <h2 class="font-display text-xs font-bold uppercase tracking-widest text-stone-500 mb-5">Contact</h2>
        <ul class="space-y-3.5">
          <li>
            <a href="tel:+14105550100" class="flex items-center gap-3 text-sm font-body text-stone-400 hover:text-[#C89481] transition-colors group">
              <span class="w-8 h-8 rounded-lg bg-stone-900/80 border border-stone-800 flex items-center justify-center flex-shrink-0 group-hover:border-[#C89481]/30 group-hover:bg-[#C89481]/5 transition-all">
                <svg class="w-3.5 h-3.5 text-[#C89481]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              </span>
              <span>(410) 555-0100</span>
            </a>
          </li>
          <li>
            <a href="mailto:john@baltimoreweddingplanner.com" class="flex items-center gap-3 text-sm font-body text-stone-400 hover:text-[#C89481] transition-colors group">
              <span class="w-8 h-8 rounded-lg bg-stone-900/80 border border-stone-800 flex items-center justify-center flex-shrink-0 group-hover:border-[#C89481]/30 group-hover:bg-[#C89481]/5 transition-all">
                <svg class="w-3.5 h-3.5 text-[#C89481]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              </span>
              <span class="text-xs">john@baltimore<wbr>weddingplanner.com</span>
            </a>
          </li>
          <li>
            <span class="flex items-center gap-3 text-sm font-body text-stone-400">
              <span class="w-8 h-8 rounded-lg bg-stone-900/80 border border-stone-800 flex items-center justify-center flex-shrink-0">
                <svg class="w-3.5 h-3.5 text-[#C89481]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              </span>
              <span class="text-xs">Baltimore, MD — All of Maryland</span>
            </span>
          </li>
        </ul>
      </div>

      <!-- Social / Follow -->
      <div class="lg:col-span-3 flex flex-col items-start">
        <h2 class="font-display text-xs font-bold uppercase tracking-widest text-stone-500 mb-5">Follow Along</h2>
        <div class="flex gap-2.5 mb-5">
          <!-- Instagram -->
          <a href="#" aria-label="Instagram" class="w-9 h-9 rounded-xl bg-stone-900/80 border border-stone-800 flex items-center justify-center text-stone-500 hover:text-[#C89481] hover:border-[#C89481]/30 hover:bg-[#C89481]/5 transition-all duration-200">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8a5 5 0 015-5h8a5 5 0 015 5v8a5 5 0 01-5 5H8a5 5 0 01-5-5V8z" /><circle cx="12" cy="12" r="3" /><circle cx="17" cy="7" r="1" fill="currentColor" /></svg>
          </a>
          <!-- Pinterest -->
          <a href="#" aria-label="Pinterest" class="w-9 h-9 rounded-xl bg-stone-900/80 border border-stone-800 flex items-center justify-center text-stone-500 hover:text-[#C89481] hover:border-[#C89481]/30 hover:bg-[#C89481]/5 transition-all duration-200">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="9" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5c-2.21 0-4 1.79-4 4 0 1.66.92 3.11 2.28 3.87M12 7.5v5.25l-1.5 1.5" /></svg>
          </a>
          <!-- Facebook -->
          <a href="#" aria-label="Facebook" class="w-9 h-9 rounded-xl bg-stone-900/80 border border-stone-800 flex items-center justify-center text-stone-500 hover:text-[#C89481] hover:border-[#C89481]/30 hover:bg-[#C89481]/5 transition-all duration-200">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3V2z" /></svg>
          </a>
          <!-- TikTok -->
          <a href="#" aria-label="TikTok" class="w-9 h-9 rounded-xl bg-stone-900/80 border border-stone-800 flex items-center justify-center text-stone-500 hover:text-[#C89481] hover:border-[#C89481]/30 hover:bg-[#C89481]/5 transition-all duration-200">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 2v15.5a3.5 3.5 0 01-3.5 3.5A3.5 3.5 0 015 17.5 3.5 3.5 0 018.5 14V2" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 2c2.21 0 4 1.79 4 4h-4V2z" /></svg>
          </a>
        </div>
        <p class="text-[11px] font-body text-stone-600 leading-relaxed">Follow for real Maryland wedding inspo, budget tips, and venue tours.</p>
      </div>
    </div>

    <!-- Middle section: Links grid -->
    <div class="grid grid-cols-2 md:grid-cols-12 gap-x-8 gap-y-10 py-14 border-b border-stone-900/60">

      <!-- Services -->
      <div class="col-span-2">
        <h2 class="font-display text-xs font-bold uppercase tracking-widest text-stone-500 mb-5">Services</h2>
        <ul class="space-y-3">
          <li><a href="/services/full-service-wedding-planning" class="text-sm font-body text-stone-400 hover:text-[#C89481] transition-colors">Full-Service Planning</a></li>
          <li><a href="/services/day-of-wedding-coordinator" class="text-sm font-body text-stone-400 hover:text-[#C89481] transition-colors">Day-of Coordination</a></li>
          <li><a href="/services/partial-wedding-planning" class="text-sm font-body text-stone-400 hover:text-[#C89481] transition-colors">Partial Planning</a></li>
          <li><a href="/services/elopement-planner-maryland" class="text-sm font-body text-stone-400 hover:text-[#C89481] transition-colors">Elopement Planning</a></li>
        </ul>
      </div>

      <!-- Pricing & About -->
      <div class="col-span-2">
        <h2 class="font-display text-xs font-bold uppercase tracking-widest text-stone-500 mb-5">Company</h2>
        <ul class="space-y-3">
          <li><a href="/wedding-planning-packages" class="text-sm font-body text-stone-400 hover:text-[#C89481] transition-colors">Packages & Pricing</a></li>
          <li><a href="/about" class="text-sm font-body text-stone-400 hover:text-[#C89481] transition-colors">About John</a></li>
          <li><a href="/faq" class="text-sm font-body text-stone-400 hover:text-[#C89481] transition-colors">FAQ</a></li>
          <li><a href="/contact" class="text-sm font-body text-stone-400 hover:text-[#C89481] transition-colors">Book a Consultation</a></li>
        </ul>
      </div>

      <!-- Popular Guides -->
      <div class="col-span-3">
        <h2 class="font-display text-xs font-bold uppercase tracking-widest text-stone-500 mb-5">Popular Guides</h2>
        <ul class="space-y-3">
          {popularGuides.map((guide) => (
            <li><a href={guide.href} class="text-sm font-body text-stone-400 hover:text-[#C89481] transition-colors">{guide.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Service Areas -->
      <div class="col-span-2">
        <h2 class="font-display text-xs font-bold uppercase tracking-widest text-stone-500 mb-5">Service Areas</h2>
        <ul class="space-y-3">
          <li><a href="/locations/annapolis-wedding-planner" class="text-sm font-body text-stone-400 hover:text-[#C89481] transition-colors">Annapolis, MD</a></li>
          <li><a href="/locations/columbia-md-wedding-planner" class="text-sm font-body text-stone-400 hover:text-[#C89481] transition-colors">Columbia, MD</a></li>
          <li><a href="/locations/towson-wedding-planner" class="text-sm font-body text-stone-400 hover:text-[#C89481] transition-colors">Towson, MD</a></li>
          <li><a href="/locations/frederick-wedding-planner" class="text-sm font-body text-stone-400 hover:text-[#C89481] transition-colors">Frederick, MD</a></li>
          <li><a href="/locations/rockville-wedding-planner" class="text-sm font-body text-stone-400 hover:text-[#C89481] transition-colors">Rockville, MD</a></li>
        </ul>
      </div>

      <!-- Info -->
      <div class="col-span-3 md:col-span-3">
        <h2 class="font-display text-xs font-bold uppercase tracking-widest text-stone-500 mb-5">Get in Touch</h2>
        <ul class="space-y-3">
          <li><a href="/blog" class="text-sm font-body text-stone-400 hover:text-[#C89481] transition-colors">All Blog Posts</a></li>
          <li><a href="/locations" class="text-sm font-body text-stone-400 hover:text-[#C89481] transition-colors">All Service Areas</a></li>
          <li><a href="/privacy-policy" class="text-sm font-body text-stone-400 hover:text-[#C89481] transition-colors">Privacy Policy</a></li>
          <li><a href="/terms-of-service" class="text-sm font-body text-stone-400 hover:text-[#C89481] transition-colors">Terms of Service</a></li>
          <li><a href="/cookie-policy" class="text-sm font-body text-stone-400 hover:text-[#C89481] transition-colors">Cookie Policy</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar with back-to-top -->
    <div class="pt-8 flex flex-col sm:flex-row items-center justify-between gap-5">
      <div class="flex flex-col sm:flex-row items-center gap-4">
        <p class="text-xs font-body text-stone-600 text-center sm:text-left">
          &copy; {year} Baltimore Wedding Planner. Serving couples across Maryland.
        </p>
        <span class="hidden sm:inline text-stone-700">|</span>
        <p class="text-[11px] font-body text-stone-600 text-center sm:text-left">
          Built with <span class="text-[#C89481]">&#9829;</span> for budget-friendly Maryland weddings.
        </p>
      </div>
      <button
        onclick="window.scrollTo({ top: 0, behavior: 'smooth' })"
        class="w-9 h-9 rounded-xl bg-stone-900/80 border border-stone-800 flex items-center justify-center text-stone-500 hover:text-[#C89481] hover:border-[#C89481]/30 hover:bg-[#C89481]/5 transition-all duration-200 cursor-pointer"
        aria-label="Back to top"
        type="button"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" /></svg>
      </button>
    </div>
  </div>
</footer>
