---
// Cookie Consent Banner — GDPR + CCPA compliant
// Consent Mode v2 compatible — fires gtag consent signals
// Stored in localStorage as 'bwp_consent': 'accepted' | 'rejected'
---

<div
  id="cookie-banner"
  class="fixed bottom-0 left-0 right-0 z-50 bg-stone-950/95 backdrop-blur-md text-white px-4 py-4 border-t border-stone-800/60 shadow-2xl hidden"
  role="dialog"
  aria-label="Cookie consent"
  aria-live="polite"
>
  <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
    <div class="flex-1 max-w-2xl">
      <p class="text-xs font-body text-stone-300 leading-relaxed">
        We use analytics cookies (Google Analytics 4, Microsoft Clarity) to understand how visitors use our site and improve it. No advertising cookies. No data sold.
        <a href="/cookie-policy" class="text-[#C89481] hover:underline ml-1">Cookie Policy</a>
        <span class="mx-1 text-stone-600">|</span>
        <a href="/privacy-policy" class="text-[#C89481] hover:underline">Privacy Policy</a>
      </p>
    </div>
    <div class="flex items-center gap-2 flex-shrink-0">
      <button
        id="cookie-reject"
        class="px-4 py-2 text-xs font-display font-semibold uppercase tracking-wider text-stone-300 border border-stone-700 hover:border-stone-500 hover:text-white rounded-xl transition-all duration-200"
        type="button"
      >
        Reject
      </button>
      <button
        id="cookie-accept"
        class="px-4 py-2 text-xs font-display font-semibold uppercase tracking-wider bg-[#C89481] hover:bg-[#B5826F] text-white rounded-xl transition-all duration-200"
        type="button"
      >
        Accept Analytics
      </button>
    </div>
  </div>
</div>

<script>
  // Cookie Consent Manager — Consent Mode v2 compatible
  const CONSENT_KEY = 'bwp_consent';
  const BANNER_ID = 'cookie-banner';

  function getConsent(): string | null {
    try {
      return localStorage.getItem(CONSENT_KEY);
    } catch {
      return null;
    }
  }

  function setConsent(value: 'accepted' | 'rejected'): void {
    try {
      localStorage.setItem(CONSENT_KEY, value);
    } catch {}
  }

  function hideBanner(): void {
    const banner = document.getElementById(BANNER_ID);
    if (banner) {
      banner.style.display = 'none';
      banner.classList.add('hidden');
    }
  }

  function showBanner(): void {
    const banner = document.getElementById(BANNER_ID);
    if (banner) {
      banner.classList.remove('hidden');
      banner.style.display = '';
    }
  }

  // Consent Mode v2: update GA4 consent signals
  function updateGtagConsent(granted: boolean): void {
    if (typeof (window as any).gtag === 'function') {
      (window as any).gtag('consent', 'update', {
        analytics_storage: granted ? 'granted' : 'denied',
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
      });
    }
  }

  // Initialize on page load
  document.addEventListener('DOMContentLoaded', () => {
    const consent = getConsent();

    if (!consent) {
      // No prior consent — show banner after brief delay
      setTimeout(showBanner, 1200);
    } else if (consent === 'accepted') {
      updateGtagConsent(true);
    } else {
      updateGtagConsent(false);
    }

    // Accept button
    const acceptBtn = document.getElementById('cookie-accept');
    acceptBtn?.addEventListener('click', () => {
      setConsent('accepted');
      updateGtagConsent(true);
      hideBanner();
    });

    // Reject button
    const rejectBtn = document.getElementById('cookie-reject');
    rejectBtn?.addEventListener('click', () => {
      setConsent('rejected');
      updateGtagConsent(false);
      hideBanner();
    });
  });

  // Expose reset function for footer "Cookie Preferences" link
  (window as any).resetCookieConsent = () => {
    try { localStorage.removeItem(CONSENT_KEY); } catch {}
    showBanner();
  };
</script>
