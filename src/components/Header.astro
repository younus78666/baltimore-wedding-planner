---
const pathname = Astro.url.pathname;

const services = [
  { label: 'Full-Service Planning', href: '/services/full-service-wedding-planning' },
  { label: 'Day-of Coordination', href: '/services/day-of-wedding-coordinator' },
  { label: 'Partial Planning', href: '/services/partial-wedding-planning' },
  { label: 'Elopement Planning', href: '/services/elopement-planner-maryland' },
];
---

<!-- TOP NOTIFICATION BAR -->
<div class="bg-[#1C1816] text-stone-300 py-2.5 px-4 text-[11px] font-sans border-b border-stone-800/50 relative z-50">
  <div class="max-w-site mx-auto flex flex-col sm:flex-row justify-between items-center gap-1.5">
    <div class="flex flex-wrap justify-center sm:justify-start items-center gap-x-5 gap-y-1">
      <a href="tel:+14105550100" class="flex items-center gap-1.5 hover:text-[#C89481] transition-colors duration-200">
        <svg class="w-3.5 h-3.5 text-[#C89481]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
        (410) 555-0100
      </a>
      <a href="mailto:john@baltimoreweddingplanner.com" class="flex items-center gap-1.5 hover:text-[#C89481] transition-colors duration-200">
        <svg class="w-3.5 h-3.5 text-[#C89481]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
        john@baltimoreweddingplanner.com
      </a>
    </div>
    <div class="flex items-center gap-3">
      <span class="inline-flex items-center gap-1 bg-amber-500/10 text-amber-400 text-[9px] uppercase font-bold tracking-widest px-2.5 py-0.5 rounded border border-amber-500/20">
        ★ 5-Star Rated on Google
      </span>
      <span class="text-stone-500 hidden md:inline text-[10px]">| Greater Baltimore and All of Maryland</span>
    </div>
  </div>
</div>

<!-- MAIN NAVIGATION -->
<header class="sticky top-0 z-40 bg-[#FAF7F5]/92 backdrop-blur-md border-b border-stone-200/50 shadow-sm">
  <div class="max-w-site mx-auto px-4 sm:px-6 lg:px-8">
    <nav class="flex items-center justify-between h-18 md:h-20" aria-label="Main navigation">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group" aria-label="Baltimore Wedding Planner — Home">
        <div class="w-9 h-9 bg-[#C89481]/15 rounded-xl border border-[#C89481]/30 flex items-center justify-center group-hover:bg-[#C89481]/25 transition-all duration-300">
          <svg class="w-4.5 h-4.5 text-[#915B49] fill-current" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
          </svg>
        </div>
        <div class="flex flex-col text-left leading-tight">
          <span class="font-display font-bold text-[#1C1816] text-base tracking-tight group-hover:text-[#915B49] transition-colors">
            Baltimore Wedding Planner
          </span>
          <span class="font-serif italic text-[#C89481] text-[10px] tracking-wide">
            Budget Weddings Across Maryland
          </span>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-7 lg:gap-9">

        <!-- Services dropdown -->
        <div class="relative group">
          <button
            class="flex items-center gap-1 text-xs font-display font-bold tracking-wider text-stone-600 uppercase hover:text-[#915B49] transition-colors py-2"
            aria-haspopup="true"
          >
            Services
            <svg class="w-3.5 h-3.5 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div
            class="absolute top-full left-0 mt-1 w-56 bg-white/95 backdrop-blur-sm border border-stone-200/60 rounded-2xl shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 overflow-hidden"
            role="menu"
          >
            {services.map((s) => (
              <a
                href={s.href}
                class={`block px-4 py-3 text-xs font-body border-b border-stone-100 last:border-0 transition-colors ${
                  pathname === s.href
                    ? 'text-[#915B49] font-semibold bg-terracotta-50'
                    : 'text-stone-700 hover:bg-[#FAF1EE] hover:text-[#915B49]'
                }`}
                role="menuitem"
              >
                {s.label}
              </a>
            ))}
          </div>
        </div>

        <a href="/wedding-planning-packages" class={`text-xs font-display font-bold tracking-wider uppercase transition-colors ${pathname === '/wedding-planning-packages' ? 'text-[#915B49]' : 'text-stone-600 hover:text-[#915B49]'}`}>
          Pricing
        </a>
        <a href="/about" class={`text-xs font-display font-bold tracking-wider uppercase transition-colors ${pathname === '/about' ? 'text-[#915B49]' : 'text-stone-600 hover:text-[#915B49]'}`}>
          About
        </a>
        <a href="/blog" class={`text-xs font-display font-bold tracking-wider uppercase transition-colors ${pathname.startsWith('/blog') ? 'text-[#915B49]' : 'text-stone-600 hover:text-[#915B49]'}`}>
          Guides
        </a>
      </div>

      <!-- CTA + Mobile toggle -->
      <div class="flex items-center gap-3">
        <a href="/contact" class="hidden md:inline-flex btn-primary text-xs px-5 py-2.5">
          Free Consultation
        </a>

        <button
          id="mobile-menu-toggle"
          class="md:hidden p-2 rounded-lg text-stone-600 hover:bg-stone-100 transition-colors"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg id="icon-menu" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="icon-close" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-stone-200/50 bg-[#FAF7F5]"
    role="dialog"
    aria-label="Mobile navigation"
  >
    <div class="max-w-site mx-auto px-4 py-4 flex flex-col">
      <p class="px-3 py-2 text-xs font-display font-bold uppercase tracking-widest text-stone-400">Services</p>
      {services.map((s) => (
        <a href={s.href} class="px-3 py-3 text-sm font-body text-stone-700 hover:bg-[#FAF1EE] hover:text-[#915B49] rounded-lg transition-colors">
          {s.label}
        </a>
      ))}
      <div class="my-2 border-t border-stone-200" />
      <a href="/wedding-planning-packages" class="px-3 py-3 text-sm font-body text-stone-700 hover:bg-[#FAF1EE] hover:text-[#915B49] rounded-lg transition-colors">Packages and Pricing</a>
      <a href="/about" class="px-3 py-3 text-sm font-body text-stone-700 hover:bg-[#FAF1EE] hover:text-[#915B49] rounded-lg transition-colors">About John</a>
      <a href="/blog" class="px-3 py-3 text-sm font-body text-stone-700 hover:bg-[#FAF1EE] hover:text-[#915B49] rounded-lg transition-colors">Wedding Guides</a>
      <a href="/faq" class="px-3 py-3 text-sm font-body text-stone-700 hover:bg-[#FAF1EE] hover:text-[#915B49] rounded-lg transition-colors">FAQ</a>
      <div class="px-3 pt-3 pb-2">
        <a href="/contact" class="btn-primary w-full justify-center text-sm">Free Consultation</a>
      </div>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    iconMenu?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'Open menu' : 'Close menu');
  });
</script>
