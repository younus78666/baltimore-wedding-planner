---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page Not Found | Baltimore Wedding Planner | 404"
  description="This page doesn't exist. Find wedding planning services, venue guides, and more on the Baltimore Wedding Planner site."
  noindex={true}
>
  <section class="section bg-[#FAF1EE] min-h-[60vh] flex items-center">
    <div class="container text-center max-w-xl mx-auto">
      <p class="font-display text-8xl font-bold text-rose-light mb-4">404</p>
      <h1 class="font-display text-3xl font-bold text-charcoal mb-4">Page Not Found</h1>
      <p class="text-charcoal-muted font-body text-lg mb-8">
        This page doesn't exist. Let's get you back on track.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="btn-primary">Go to Homepage</a>
        <a href="/contact" class="btn-outline">Book a Consultation</a>
      </div>
    </div>
  </section>
</Layout>
