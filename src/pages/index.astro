---
import Layout from '../layouts/Layout.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'ProfessionalService'],
  '@id': 'https://baltimoreweddingplanner.com/#business',
  name: 'Baltimore Wedding Planner',
  description: 'Budget-friendly wedding planner serving Baltimore and all of Maryland.',
  url: 'https://baltimoreweddingplanner.com',
  telephone: '+14105550100',
  email: 'john@baltimoreweddingplanner.com',
  founder: { '@type': 'Person', name: 'John' },
  address: { '@type': 'PostalAddress', addressLocality: 'Baltimore', addressRegion: 'MD', postalCode: '21201', addressCountry: 'US' },
  geo: { '@type': 'GeoCoordinates', latitude: 39.2904, longitude: -76.6122 },
  areaServed: { '@type': 'State', name: 'Maryland', identifier: 'US-MD' },
  priceRange: '2474',
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'How much does a wedding planner cost in Baltimore?', acceptedAnswer: { '@type': 'Answer', text: "John's packages start at $500 for day-of coordination and go up to $2,800 for full-service planning." } },
    { '@type': 'Question', name: 'What areas does John serve?', acceptedAnswer: { '@type': 'Answer', text: 'John serves all of Maryland.' } },
  ],
};

const services = [
  { title: 'Full-Service Planning', desc: 'Complete wedding management from engagement to reception. Vendors, timeline, and every detail handled.', href: '/services/full-service-wedding-planning', features: ['Budget creation and tracking', 'All vendor sourcing and negotiation', 'Contract review for every vendor', 'Day-of coordination included'], featured: true, iconIdx: 0 },
  { title: 'Day-of Coordination', desc: 'John manages your wedding day from start to finish so you stay present and stress-free.', href: '/services/day-of-wedding-coordinator', features: ['Pre-wedding planning call', 'Vendor confirmation calls', '15-minute interval timeline', 'Full day coverage (10 hrs)'], featured: false, iconIdx: 1 },
  { title: 'Partial Planning', desc: "You've started. Bring John in for specific tasks, vendor negotiations, or final-stretch help.", href: '/services/partial-wedding-planning', features: ['Up to 10 consultations', 'Vendor sourcing (5 categories)', 'Contract review included', 'Day-of coordination included'], featured: false, iconIdx: 2 },
  { title: 'Elopements', desc: 'Intimate ceremonies under 30 guests, anywhere in Maryland. Permits, location, vendors all sorted.', href: '/services/elopement-planner-maryland', features: ['Location scouting', 'Permit applications', 'Officiant coordination', 'Day-of presence'], featured: false, iconIdx: 3 },
];

const steps = [
  { n: '01', title: 'Free Consultation', desc: 'Book a 30-minute call. No pressure, just clarity on what your vision looks like and what it will cost.' },
  { n: '02', title: 'Your Custom Plan', desc: 'John builds a tailored planning roadmap covering vendors, timeline, and budget milestones for your wedding.' },
  { n: '03', title: 'Your Perfect Day', desc: 'Relax and enjoy every moment. John handles the details so you and your partner can be fully present.' },
];

const testimonials = [
  { quote: "John made our $15,000 wedding feel like a million dollars. He negotiated with every vendor and kept us on budget without cutting a single corner.", name: 'Sarah & Marcus T.', location: 'Wedding at Patterson Park, Baltimore' },
  { quote: "We were planning a 20-person elopement in Annapolis and had no idea where to start. John found us the perfect waterfront spot and handled everything.", name: 'Priya & Devon K.', location: 'Elopement in Annapolis, MD' },
  { quote: "As the day-of coordinator, John kept our entire 6-hour timeline running perfectly. Our caterer ran late and he handled it before I even knew.", name: 'Amanda & Luis R.', location: 'Wedding at The Grand Baltimore' },
];

const faqs = [
  { q: "How much does a wedding planner cost in Baltimore?", a: "John's packages start at $500 for day-of coordination and go up to $2,800 for full-service planning. All packages are designed for Maryland weddings with budgets under $20,000. <a href='/wedding-planning-packages' class='text-[#C89481] hover:underline font-medium'>See full pricing here</a>." },
  { q: "What areas of Maryland does John serve?", a: 'John serves all of Maryland: Baltimore, Annapolis, Columbia, Towson, Frederick, Rockville, Silver Spring, and the Eastern Shore.' },
  { q: "What is the difference between full-service planning and day-of coordination?", a: "Full-service planning covers everything from engagement to reception over 6-18 months. Day-of coordination means John manages your wedding day timeline and vendors without prior planning involvement. <a href='/services/day-of-wedding-coordinator' class='text-[#C89481] hover:underline font-medium'>Learn about day-of coordination</a>." },
  { q: "Do you plan elopements in Maryland?", a: "Yes. Elopements and micro-weddings (under 30 guests) are a specialty. John handles location scouting, permits, officiants, and vendor coordination. <a href='/services/elopement-planner-maryland' class='text-[#C89481] hover:underline font-medium'>See elopement packages</a>." },
];

const values = [
  { title: 'Budget Honesty', desc: "Every dollar justified before it's committed. No hidden fees, no vendor kickbacks." },
  { title: 'Maryland Expertise', desc: '50+ weddings across Baltimore, Annapolis, the Eastern Shore, and Western Maryland.' },
  { title: 'Permit Specialists', desc: 'Instant support filing county marriage licenses and state park pavilion permits.' },
  { title: 'Stress-Free Process', desc: 'Over 50 successful ceremonies managed with absolute day-of peace of mind.' },
];
---

<Layout
  title="Baltimore Wedding Planner | Budget Weddings Across Maryland"
  description="Baltimore's budget-friendly wedding planner serving all of Maryland. Full-service planning, day-of coordination, and elopements. Free consultation with John."
  canonical="https://baltimoreweddingplanner.com"
  schema={[schema, faqSchema]}
>

<!-- ===== SCROLL REVEAL SCRIPT ===== -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
    );

    document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale, .stagger-children').forEach((el) => {
      observer.observe(el);
    });
  });
</script>

<!-- ===== HERO SECTION — Modern 2026 Design ===== -->
<section class="relative min-h-[90vh] flex items-center overflow-hidden bg-gradient-to-b from-[#FAF7F5] via-[#FAF1EE] to-[#FAF7F5]">
  <!-- Animated ambient background -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="absolute -top-40 -right-40 w-[600px] h-[600px] bg-gradient-to-br from-[#C89481]/10 to-[#915B49]/5 rounded-full blur-[120px] animate-float-slow" />
    <div class="absolute -bottom-32 -left-32 w-[500px] h-[500px] bg-gradient-to-tr from-[#E4C5B7]/15 to-[#C89481]/5 rounded-full blur-[100px] animate-float" style="animation-delay: -3s" />
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[700px] h-[700px] bg-[#FAF1EE]/80 rounded-full blur-[150px]" />
  </div>

  <!-- Subtle grid pattern overlay -->
  <div class="absolute inset-0 opacity-[0.015]" style="background-image: radial-gradient(circle at 1px 1px, #1C1816 1px, transparent 0); background-size: 40px 40px;" aria-hidden="true" />

  <div class="relative w-full px-4 sm:px-6 lg:px-8 py-20 md:py-32 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">

      <!-- Left 7 cols: headline, trust badges, CTAs -->
      <div class="lg:col-span-7 flex flex-col items-start gap-7 reveal-left">
        <div class="inline-flex items-center gap-2 bg-white/80 backdrop-blur-md text-[#915B49] text-[10px] tracking-widest font-extrabold uppercase rounded-full px-4 py-2 border border-[#C89481]/20 shadow-sm">
          <span class="flex h-2 w-2 relative">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#C89481] opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-[#C89481]"></span>
          </span>
          Serving All of Maryland
        </div>

        <h1 class="font-display font-semibold text-stone-900 tracking-tight text-[clamp(2.25rem,5vw,4rem)] leading-[1.08] max-w-2xl">
          Baltimore's Wedding Planner for Couples Who Want
          <span class="font-serif italic bg-gradient-to-r from-[#C89481] via-[#915B49] to-[#C89481] bg-clip-text text-transparent block mt-2">Beauty Without the Debt</span>
        </h1>

        <p class="text-stone-600 font-light text-base sm:text-lg max-w-xl leading-relaxed">
          John creates stunning, boutique-quality weddings for Maryland couples with smart budgets under $20,000. Full-service planning, day-of coordination, and elopements handled with exquisite care.
        </p>

        <!-- Trust badges — glass card -->
        <div class="card-glass w-full max-w-xl p-5 stagger-children">
          <div class="grid grid-cols-2 md:grid-cols-3 gap-y-3 gap-x-5">
            <div class="flex items-center gap-2.5">
              <div class="w-8 h-8 rounded-lg bg-amber-50 flex items-center justify-center shrink-0">
                <svg class="w-4 h-4 text-amber-500 fill-current" viewBox="0 0 20 20" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              </div>
              <span class="text-[11px] font-semibold text-stone-800 leading-tight">5-Star Google<br />Rated</span>
            </div>
            <div class="flex items-center gap-2.5">
              <div class="w-8 h-8 rounded-lg bg-[#FAF1EE] flex items-center justify-center shrink-0">
                <svg class="w-4 h-4 text-[#915B49]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
              </div>
              <span class="text-[11px] font-semibold text-stone-800 leading-tight">50+ MD<br />Weddings</span>
            </div>
            <div class="flex items-center gap-2.5">
              <div class="w-8 h-8 rounded-lg bg-emerald-50 flex items-center justify-center shrink-0">
                <svg class="w-4 h-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <span class="text-[11px] font-semibold text-stone-800 leading-tight">No Hidden<br />Fees</span>
            </div>
          </div>
        </div>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto pt-2">
          <a href="/contact" class="bg-[#C89481] text-white hover:bg-[#B5826F] px-8 py-4 rounded-xl font-display text-xs font-bold tracking-wider uppercase transition-all duration-300 shadow-md text-center hover:-translate-y-1 hover:shadow-lg active:translate-y-0 btn-lift">
            Book Free Consultation
          </a>
          <a href="/wedding-planning-packages" class="group bg-white border-2 border-stone-200 hover:border-[#C89481]/40 text-stone-700 hover:text-[#915B49] px-8 py-4 rounded-xl font-display text-xs font-bold tracking-wider uppercase transition-all duration-300 text-center hover:-translate-y-1 hover:shadow-md active:translate-y-0 flex items-center justify-center gap-2">
            View All Packages
            <svg class="w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
          </a>
        </div>
      </div>

      <!-- Right 5 cols: hero visual + floating testimonial -->
      <div class="lg:col-span-5 relative flex justify-center reveal-right">
        <!-- Main hero visual -->
        <div class="relative w-full max-w-sm sm:max-w-md">
          <!-- Glow behind image -->
          <div class="absolute -inset-8 bg-gradient-to-br from-[#C89481]/20 via-[#FAF1EE] to-[#C89481]/10 rounded-[3rem] blur-2xl animate-pulse-glow" aria-hidden="true" />

          <!-- Image container -->
          <div class="relative rounded-[2.5rem] overflow-hidden aspect-[3/4] w-full shadow-2xl bg-white/80 backdrop-blur-sm border-2 border-white/80 hover:scale-[1.02] transition-all duration-700 group">
            <div class="w-full h-full relative">
              <img
                src="/images/home-hero-planning.webp"
                width="1200"
                height="1600"
                alt="Illustration of wedding planning documents, rings, and floral details for a Maryland wedding consultation"
                class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                decoding="async"
                fetchpriority="high"
              />
            </div>
            <!-- Gradient overlay at bottom -->
            <div class="absolute inset-0 bg-gradient-to-t from-stone-900/30 via-transparent to-transparent opacity-50 pointer-events-none" aria-hidden="true" />
          </div>

          <!-- Floating testimonial card -->
          <div class="absolute -bottom-6 -left-4 md:-left-8 bg-white/90 backdrop-blur-xl p-5 rounded-2xl shadow-xl border border-white/80 max-w-[280px] space-y-1.5 z-10 hover:-translate-y-1 hover:shadow-2xl transition-all duration-500">
            <div class="flex gap-0.5 text-amber-400 mb-1" aria-label="5 stars">
              {[1,2,3,4,5].map(() => (
                <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 20 20" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <p class="text-stone-700 text-[11px] leading-relaxed italic font-light">"Working with John was the absolute best choice we made."</p>
            <p class="text-[#C89481] text-[10px] uppercase tracking-widest font-bold pt-0.5">— Sarah & Marcus, Baltimore</p>
          </div>
        </div>
      </div>
    </div>

    <!-- "As Featured In" social proof strip -->
    <div class="mt-20 pt-10 border-t border-[#C89481]/10 reveal">
      <p class="text-center font-sans uppercase tracking-[0.25em] text-[10px] font-bold text-stone-400 mb-8">As Featured In</p>
      <div class="flex flex-wrap justify-center items-center gap-x-14 gap-y-6 opacity-50 hover:opacity-80 transition-all duration-700">
        <span class="font-serif font-extrabold text-sm tracking-tight text-stone-500 select-none hover:text-[#915B49] transition-colors duration-300">The Baltimore Sun</span>
        <span class="font-sans font-bold text-base tracking-widest uppercase text-stone-500 select-none hover:text-[#915B49] transition-colors duration-300">THE KNOT</span>
        <span class="font-serif italic text-base font-bold text-stone-500 select-none hover:text-[#915B49] transition-colors duration-300">Chesapeake Style</span>
        <span class="font-sans font-extrabold text-sm tracking-tight text-stone-500 select-none hover:text-[#915B49] transition-colors duration-300">WeddingWire <span class="text-stone-400 font-light">MD</span></span>
        <span class="font-serif text-sm tracking-widest uppercase text-stone-500 select-none hover:text-[#915B49] transition-colors duration-300">ANNAPOLIS BRIDE</span>
      </div>
    </div>
  </div>
</section>

<!-- ===== STATS BAR — Animated Counter Section ===== -->
<section class="relative bg-gradient-to-r from-[#1C1816] to-[#2D2522] py-14 md:py-16 overflow-hidden">
  <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 30px 30px;" aria-hidden="true" />
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-4 divide-y md:divide-y-0 md:divide-x divide-white/10 text-center stagger-children">
      <div class="flex flex-col items-center justify-center py-4 md:py-0">
        <span class="font-display font-bold text-5xl lg:text-6xl text-white tracking-tight reveal" style="will-change: transform;">50+</span>
        <span class="text-stone-400 font-sans text-[11px] font-semibold uppercase tracking-[0.2em] mt-2">Maryland Weddings</span>
      </div>
      <div class="flex flex-col items-center justify-center py-4 md:py-0">
        <span class="font-display font-bold text-5xl lg:text-6xl text-white tracking-tight reveal" style="will-change: transform;">All MD</span>
        <span class="text-stone-400 font-sans text-[11px] font-semibold uppercase tracking-[0.2em] mt-2">Service Area</span>
      </div>
      <div class="flex flex-col items-center justify-center py-4 md:py-0">
        <span class="font-display font-bold text-5xl lg:text-6xl text-white tracking-tight reveal" style="will-change: transform;">$0</span>
        <span class="text-stone-400 font-sans text-[11px] font-semibold uppercase tracking-[0.2em] mt-2">Consultation Fee</span>
      </div>
    </div>
  </div>
</section>

<!-- ===== SERVICES — Bento-inspired Grid ===== -->
<section class="px-4 sm:px-6 lg:px-8 py-20 md:py-28 max-w-7xl mx-auto" id="services-section">
  <div class="text-center max-w-3xl mx-auto space-y-5 reveal">
    <span class="inline-flex items-center gap-2 text-[#915B49] text-[10px] tracking-[0.25em] font-sans font-extrabold uppercase bg-white/80 backdrop-blur-sm px-4 py-2 rounded-full border border-[#C89481]/25 shadow-sm">PLANS & PRICING</span>
    <h2 class="font-display text-3xl md:text-5xl font-semibold tracking-tight text-stone-900 leading-tight">Bespoke Services Configured For Your Budget</h2>
    <p class="text-stone-600 font-light text-sm md:text-base leading-relaxed max-w-2xl mx-auto">Choose full-service blueprints, day-of management, or elopement coordination. John adjusts every structure to protect your budget limit.</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mt-14 stagger-children">
    {services.map((svc) => (
      <div class={`card-glass group relative flex flex-col justify-between p-7 sm:p-8 bento-item ${svc.featured ? 'ring-2 ring-[#C89481]/40 shadow-lg shadow-[#C89481]/5' : ''}`}>
        <!-- Featured badge -->
        {svc.featured && (
          <div class="absolute top-0 right-0">
            <div class="bg-gradient-to-r from-[#915B49] to-[#C89481] text-white text-[8px] font-extrabold uppercase tracking-widest px-3 py-1.5 rounded-bl-xl rounded-tr-[calc(1.5rem-1px)] shadow-md">Most Popular</div>
          </div>
        )}
        <div class="space-y-5">
          <div class={`w-11 h-11 rounded-2xl flex items-center justify-center transition-all duration-500 group-hover:scale-110 group-hover:rotate-3 shadow-sm ${
            svc.iconIdx === 0 ? 'bg-gradient-to-br from-[#FAF1EE] to-[#FDF5F1] text-[#915B49] border border-[#C89481]/20' : 
            svc.iconIdx === 1 ? 'bg-gradient-to-br from-stone-50 to-stone-100 text-stone-700 border border-stone-200/50' : 
            svc.iconIdx === 2 ? 'bg-gradient-to-br from-amber-50 to-amber-100 text-amber-800 border border-amber-200/50' : 
            'bg-gradient-to-br from-emerald-50 to-emerald-100 text-emerald-800 border border-emerald-200/50'
          }`}>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              {svc.iconIdx === 0 && <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />}
              {svc.iconIdx === 1 && <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />}
              {svc.iconIdx === 2 && <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />}
              {svc.iconIdx === 3 && <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />}
            </svg>
          </div>
          <h3 class="font-display font-semibold text-lg text-stone-900 group-hover:text-[#915B49] transition-colors duration-300">{svc.title}</h3>
          <p class="text-stone-600 font-light text-xs leading-relaxed">{svc.desc}</p>
          <div class="h-px bg-gradient-to-r from-stone-200 via-stone-100 to-transparent" />
          <ul class="space-y-2.5 text-[11px] text-stone-700 font-light">
            {svc.features.map((f) => (
              <li class="flex gap-2.5 items-start">
                <svg class="w-3.5 h-3.5 text-[#C89481] mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                <span>{f}</span>
              </li>
            ))}
          </ul>
        </div>
        <a href={svc.href} class="group/btn w-full bg-[#FAF1EE] text-[#915B49] hover:bg-gradient-to-r hover:from-[#C89481] hover:to-[#B5826F] hover:text-white font-sans text-xs font-bold py-3.5 rounded-xl transition-all duration-300 mt-6 border border-[#C89481]/15 uppercase tracking-wide text-center block hover:-translate-y-0.5 hover:shadow-md active:translate-y-0">
          Learn More
        </a>
      </div>
    ))}
  </div>
  <div class="text-center mt-10 reveal">
    <a href="/wedding-planning-packages" class="group inline-flex items-center gap-2 bg-[#1C1816] text-white hover:bg-[#3D3430] px-7 py-3.5 rounded-xl text-xs font-bold tracking-wider uppercase transition-all duration-300 shadow-md hover:-translate-y-0.5 active:translate-y-0">
      Compare All Packages
      <svg class="w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
    </a>
  </div>
