---
import Layout from '../layouts/Layout.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'ProfessionalService'],
  '@id': 'https://baltimoreweddingplanner.com/#business',
  name: 'Baltimore Wedding Planner',
  description: 'Budget-friendly wedding planner serving Baltimore and all of Maryland.',
  url: 'https://baltimoreweddingplanner.com',
  telephone: '+14105550100',
  email: 'john@baltimoreweddingplanner.com',
  founder: { '@type': 'Person', name: 'John' },
  address: { '@type': 'PostalAddress', addressLocality: 'Baltimore', addressRegion: 'MD', postalCode: '21201', addressCountry: 'US' },
  geo: { '@type': 'GeoCoordinates', latitude: 39.2904, longitude: -76.6122 },
  areaServed: { '@type': 'State', name: 'Maryland', identifier: 'US-MD' },
  priceRange: '2474',
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'How much does a wedding planner cost in Baltimore?', acceptedAnswer: { '@type': 'Answer', text: "John's packages start at $500 for day-of coordination and go up to $2,800 for full-service planning." } },
    { '@type': 'Question', name: 'What areas does John serve?', acceptedAnswer: { '@type': 'Answer', text: 'John serves all of Maryland.' } },
  ],
};

const services = [
  { title: 'Full-Service Planning', desc: 'Complete wedding management from engagement to reception. Vendors, timeline, and every detail handled.', href: '/services/full-service-wedding-planning', features: ['Budget creation and tracking', 'All vendor sourcing and negotiation', 'Contract review for every vendor', 'Day-of coordination included'], featured: true, iconIdx: 0 },
  { title: 'Day-of Coordination', desc: 'John manages your wedding day from start to finish so you stay present and stress-free.', href: '/services/day-of-wedding-coordinator', features: ['Pre-wedding planning call', 'Vendor confirmation calls', '15-minute interval timeline', 'Full day coverage (10 hrs)'], featured: false, iconIdx: 1 },
  { title: 'Partial Planning', desc: "You've started. Bring John in for specific tasks, vendor negotiations, or final-stretch help.", href: '/services/partial-wedding-planning', features: ['Up to 10 consultations', 'Vendor sourcing (5 categories)', 'Contract review included', 'Day-of coordination included'], featured: false, iconIdx: 2 },
  { title: 'Elopements', desc: 'Intimate ceremonies under 30 guests, anywhere in Maryland. Permits, location, vendors all sorted.', href: '/services/elopement-planner-maryland', features: ['Location scouting', 'Permit applications', 'Officiant coordination', 'Day-of presence'], featured: false, iconIdx: 3 },
];

const steps = [
  { n: '01', title: 'Free Consultation', desc: 'Book a 30-minute call. No pressure, just clarity on what your vision looks like and what it will cost.' },
  { n: '02', title: 'Your Custom Plan', desc: 'John builds a tailored planning roadmap covering vendors, timeline, and budget milestones for your wedding.' },
  { n: '03', title: 'Your Perfect Day', desc: 'Relax and enjoy every moment. John handles the details so you and your partner can be fully present.' },
];

const testimonials = [
  { quote: "John made our $15,000 wedding feel like a million dollars. He negotiated with every vendor and kept us on budget without cutting a single corner.", name: 'Sarah & Marcus T.', location: 'Wedding at Patterson Park, Baltimore' },
  { quote: "We were planning a 20-person elopement in Annapolis and had no idea where to start. John found us the perfect waterfront spot and handled everything.", name: 'Priya & Devon K.', location: 'Elopement in Annapolis, MD' },
  { quote: "As the day-of coordinator, John kept our entire 6-hour timeline running perfectly. Our caterer ran late and he handled it before I even knew.", name: 'Amanda & Luis R.', location: 'Wedding at The Grand Baltimore' },
];

const faqs = [
  { q: "How much does a wedding planner cost in Baltimore?", a: "John's packages start at $500 for day-of coordination and go up to $2,800 for full-service planning. All packages are designed for Maryland weddings with budgets under $20,000. <a href='/wedding-planning-packages' class='text-[#C89481] hover:underline'>See full pricing here</a>." },
  { q: "What areas of Maryland does John serve?", a: 'John serves all of Maryland: Baltimore, Annapolis, Columbia, Towson, Frederick, Rockville, Silver Spring, and the Eastern Shore.' },
  { q: "What is the difference between full-service planning and day-of coordination?", a: "Full-service planning covers everything from engagement to reception over 6-18 months. Day-of coordination means John manages your wedding day timeline and vendors without prior planning involvement. <a href='/services/day-of-wedding-coordinator' class='text-[#C89481] hover:underline'>Learn about day-of coordination</a>." },
  { q: "Do you plan elopements in Maryland?", a: "Yes. Elopements and micro-weddings (under 30 guests) are a specialty. John handles location scouting, permits, officiants, and vendor coordination. <a href='/services/elopement-planner-maryland' class='text-[#C89481] hover:underline'>See elopement packages</a>." },
];
---

<Layout
  title="Baltimore Wedding Planner | Budget Weddings Across Maryland"
  description="Baltimore's budget-friendly wedding planner serving all of Maryland. Full-service planning, day-of coordination, and elopements. Free consultation with John."
  canonical="https://baltimoreweddingplanner.com"
  schema={[schema, faqSchema]}
>

<!-- HERO — 12-col grid matching Google AI Studio design -->
<section class="relative px-4 sm:px-6 lg:px-8 py-14 md:py-24 max-w-7xl mx-auto overflow-hidden">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">

    <!-- Left 7 cols: headline, trust badges, CTAs -->
    <div class="lg:col-span-7 flex flex-col items-start gap-6">
      <div class="inline-flex items-center gap-1.5 bg-[#FAF1EE] text-[#915B49] text-[10px] tracking-widest font-bold uppercase rounded-lg px-3.5 py-1.5 border border-[#C89481]/15">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
        Serving All of Maryland
      </div>

      <h1 class="font-display font-medium text-stone-900 tracking-tight text-4xl sm:text-5xl lg:text-6xl leading-[1.1]">
        Baltimore's Wedding Planner for Couples Who Want
        <span class="font-serif italic text-[#C89481] block mt-1">Beauty Without the Debt</span>
      </h1>

      <p class="text-stone-600 font-light text-base sm:text-lg max-w-xl leading-relaxed">
        John creates stunning, boutique-quality weddings for Maryland couples with smart budgets under $20,000. Full-service planning, day-of coordination, and elopements handled with exquisite care.
      </p>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-y-3 gap-x-5 bg-white/50 p-4 border border-stone-200/50 rounded-2xl w-full max-w-xl">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-amber-500 fill-current" viewBox="0 0 20 20" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          <span class="text-[11px] font-semibold text-stone-800">5-Star Google Rated</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-[#915B49]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          <span class="text-[11px] font-semibold text-stone-800">50+ MD Weddings</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-[#915B49]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span class="text-[11px] font-semibold text-stone-800">No Hidden Fees</span>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row gap-3 w-full sm:w-auto pt-2">
        <a href="/contact" class="bg-[#C89481] text-white hover:bg-[#B5826F] px-8 py-4 rounded-xl font-display text-xs font-bold tracking-wider uppercase transition-all duration-300 shadow-md text-center hover:-translate-y-0.5">
          Book Free Consultation
        </a>
        <a href="/wedding-planning-packages" class="bg-white border border-stone-200 hover:border-stone-300 text-stone-700 hover:bg-stone-50 px-8 py-4 rounded-xl font-display text-xs font-bold tracking-wider uppercase transition-all text-center hover:-translate-y-0.5">
          View All Packages
        </a>
      </div>
    </div>

    <!-- Right 5 cols: image + floating testimonial -->
    <div class="lg:col-span-5 relative flex justify-center">
      <div class="relative rounded-[2.5rem] overflow-hidden aspect-[3/4] w-full max-w-sm sm:max-w-md shadow-xl bg-stone-100 border-4 border-white hover:scale-[1.01] transition-all duration-500">
        <div class="w-full h-full bg-[#FAF1EE] flex flex-col items-center justify-center">
          <svg class="w-24 h-24 text-[#C89481] opacity-20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="0.75" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          <p class="text-xs text-[#C89481] opacity-30 mt-2">Wedding hero photo, replace with real image</p>
        </div>
        <div class="absolute inset-0 bg-gradient-to-t from-stone-900/40 via-transparent to-transparent opacity-60 pointer-events-none" aria-hidden="true" />
      </div>
      <div class="absolute -bottom-6 -left-4 md:-left-8 bg-white/95 backdrop-blur-md p-5 rounded-2xl shadow-xl border border-stone-200/65 max-w-[270px] space-y-1 text-left z-10">
        <div class="flex gap-0.5 text-amber-500 mb-1" aria-label="5 stars">
          {[1,2,3,4,5].map(() => (
            <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 20 20" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          ))}
        </div>
        <p class="text-stone-800 text-[11px] leading-relaxed italic font-light">"Working with John was the absolute best choice we made."</p>
        <p class="text-[#C89481] text-[10px] uppercase tracking-widest font-bold pt-1">— Sarah & Marcus, Baltimore</p>
      </div>
    </div>
  </div>

  <!-- Social proof strip (as featured in) -->
  <div class="mt-16 pt-8 border-t border-stone-200/60">
    <p class="text-center font-sans uppercase tracking-[0.2em] text-[10px] font-bold text-stone-500 mb-6">Maryland Wedding Expertise: As Featured In</p>
    <div class="flex flex-wrap justify-center items-center gap-x-12 gap-y-6 opacity-60 grayscale hover:grayscale-0 hover:opacity-80 transition-all duration-500">
      <span class="font-serif font-extrabold text-base tracking-tight text-stone-600 select-none">The Baltimore Sun</span>
      <span class="font-sans font-bold text-lg tracking-widest uppercase text-stone-600 select-none">THE KNOT</span>
      <span class="font-serif italic text-lg font-bold text-stone-600 select-none">Chesapeake Style</span>
      <span class="font-sans font-extrabold text-base tracking-tight text-stone-600 select-none">WeddingWire <span class="text-stone-400 font-light">MD</span></span>
      <span class="font-serif text-base tracking-widest uppercase text-stone-600 select-none">ANNAPOLIS BRIDE</span>
    </div>
  </div>
</section>

<!-- STATS BAR — white bg, 3 cols with dividers -->
<section class="bg-white border-y border-stone-200/50 py-10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-4 divide-y md:divide-y-0 md:divide-x divide-stone-200/60 text-center">
    <div class="flex flex-col items-center justify-center py-2 md:py-0">
      <span class="font-display font-bold text-4xl lg:text-5xl text-stone-900 tracking-tight">50+</span>
      <span class="text-stone-500 font-sans text-[11px] font-semibold uppercase tracking-widest mt-1">Maryland Weddings</span>
    </div>
    <div class="flex flex-col items-center justify-center py-4 md:py-0">
      <span class="font-display font-bold text-4xl lg:text-5xl text-stone-900 tracking-tight">All MD</span>
      <span class="text-stone-500 font-sans text-[11px] font-semibold uppercase tracking-widest mt-1">Service Area</span>
    </div>
    <div class="flex flex-col items-center justify-center py-2 md:py-0">
      <span class="font-display font-bold text-4xl lg:text-5xl text-stone-900 tracking-tight">$0</span>
      <span class="text-stone-500 font-sans text-[11px] font-semibold uppercase tracking-widest mt-1">Consultation Fee</span>
    </div>
  </div>
</section>

<!-- SERVICES — 4-col rounded-[2rem] cards (exact App.tsx design) -->
<section class="px-4 sm:px-6 lg:px-8 py-16 md:py-24 max-w-7xl mx-auto space-y-12" id="services-section">
  <div class="text-center max-w-3xl mx-auto space-y-4">
    <span class="text-[#915B49] text-[10px] tracking-[0.25em] font-sans font-extrabold uppercase bg-[#FAF1EE] px-4 py-1.5 rounded-full border border-[#C89481]/25 inline-block">PLANS & PRICING</span>
    <h2 class="font-display text-3xl md:text-4xl font-semibold tracking-tight text-stone-900">Bespoke Services Configured For Your Budget</h2>
    <p class="text-stone-600 font-light text-sm md:text-base leading-relaxed max-w-2xl mx-auto">Choose full-service blueprints, day-of management, or elopement coordination. John adjusts every structure to protect your budget limit.</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    {services.map((svc) => (
      <div class={`bg-white border rounded-[2rem] p-6 sm:p-8 flex flex-col justify-between hover:shadow-lg hover:-translate-y-1 transition-all duration-300 relative group overflow-hidden ${svc.featured ? 'border-[#C89481] ring-1 ring-[#C89481]/30' : 'border-stone-200 hover:border-[#C89481]/40'}`}>
        <div class="space-y-5">
          <div class="flex justify-between items-center">
            <div class={`p-3 rounded-2xl transition duration-300 group-hover:scale-110 shadow-sm ${svc.iconIdx === 0 ? 'bg-[#FAF1EE] text-[#915B49] border border-[#C89481]/30' : svc.iconIdx === 1 ? 'bg-stone-100 text-stone-800' : svc.iconIdx === 2 ? 'bg-amber-50 text-amber-900 border border-amber-200/50' : 'bg-emerald-50 text-emerald-900 border border-emerald-200/50'}`}>
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                {svc.iconIdx === 0 && <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />}
                {svc.iconIdx === 1 && <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />}
                {svc.iconIdx === 2 && <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />}
                {svc.iconIdx === 3 && <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />}
              </svg>
            </div>
            {svc.featured && <span class="text-[9px] font-extrabold uppercase tracking-widest bg-[#915B49] text-white px-2.5 py-1 rounded-md">Most Popular</span>}
          </div>
          <h3 class="font-display font-semibold text-lg text-stone-900 group-hover:text-[#915B49] transition duration-300">{svc.title}</h3>
          <p class="text-stone-600 font-light text-xs leading-relaxed">{svc.desc}</p>
          <hr class="border-stone-100" />
          <ul class="space-y-2.5 text-[11px] text-stone-700 font-light">
            {svc.features.map((f) => (
              <li class="flex gap-2.5 items-start">
                <svg class="w-3.5 h-3.5 text-[#C89481] mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                <span>{f}</span>
              </li>
            ))}
          </ul>
        </div>
        <a href={svc.href} class="w-full bg-[#FAF1EE] text-[#915B49] hover:bg-[#C89481] hover:text-white font-sans text-xs font-bold py-3.5 rounded-xl transition duration-300 mt-6 border border-[#C89481]/15 uppercase tracking-wide text-center block">
          Learn More
        </a>
      </div>
    ))}
  </div>
  <div class="text-center pt-2">
    <a href="/wedding-planning-packages" class="inline-flex items-center gap-2 bg-[#FAF1EE] border border-[#C89481]/15 text-[#915B49] hover:bg-[#C89481] hover:text-white px-7 py-3.5 rounded-xl text-xs font-bold tracking-wider uppercase transition shadow-sm">
      Compare All Packages
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
    </a>
  </div>
</section>

<!-- VENUE GUIDES — Quality Nodes 2-col -->
<section class="px-4 sm:px-6 lg:px-8 py-16 md:py-20 bg-stone-50 border-y border-stone-200/50">
  <div class="max-w-7xl mx-auto space-y-10">
    <div class="text-center space-y-3">
      <span class="text-[#915B49] text-[10px] tracking-[0.25em] font-sans font-extrabold uppercase bg-[#FAF1EE] px-4 py-1.5 rounded-full border border-[#C89481]/25 inline-block">FREE RESOURCES</span>
      <h2 class="font-display text-3xl md:text-4xl font-semibold tracking-tight text-stone-900">Maryland Wedding Planning Guides</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <a href="/blog/baltimore-wedding-venues" class="bg-white border border-stone-200/80 rounded-[2rem] overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all duration-300 group">
        <div class="h-52 bg-[#FAF1EE] flex items-center justify-center">
          <svg class="w-16 h-16 text-[#C89481] opacity-20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="0.75" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
        </div>
        <div class="p-7">
          <span class="text-[9px] font-bold uppercase tracking-widest text-[#915B49] bg-[#FAF1EE] px-2.5 py-1 rounded-full border border-[#C89481]/20">Venue Guide</span>
          <h3 class="font-display text-xl font-semibold text-stone-900 mt-4 mb-2 group-hover:text-[#915B49] transition">Best Baltimore Wedding Venues for Every Budget in 2026</h3>
          <p class="text-stone-500 text-xs font-light leading-relaxed">Industrial lofts, historic mansions, waterfront spaces, and public parks. Real 2026 pricing reviewed by a local planner.</p>
          <span class="text-[#C89481] text-xs font-bold uppercase tracking-wider inline-flex items-center gap-1 mt-4">Read Guide <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg></span>
        </div>
      </a>
      <a href="/blog/wedding-venues-in-maryland" class="bg-white border border-stone-200/80 rounded-[2rem] overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all duration-300 group">
        <div class="h-52 bg-stone-100 flex items-center justify-center">
          <svg class="w-16 h-16 text-stone-400 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="0.75" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" /></svg>
        </div>
        <div class="p-7">
          <span class="text-[9px] font-bold uppercase tracking-widest text-stone-600 bg-stone-100 px-2.5 py-1 rounded-full border border-stone-300/50">Statewide Guide</span>
          <h3 class="font-display text-xl font-semibold text-stone-900 mt-4 mb-2 group-hover:text-[#915B49] transition">Best Wedding Venues in Maryland: Complete 2026 Guide</h3>
          <p class="text-stone-500 text-xs font-light leading-relaxed">25+ Maryland wedding venues by region: Baltimore, Annapolis, Eastern Shore, DC suburbs. Real pricing from a local planner.</p>
