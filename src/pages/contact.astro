---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
---

<Layout
  title="Book a Free Consultation | Baltimore Wedding Planner"
  description="Book a free 30-minute consultation with John, Baltimore's wedding planner. He serves all of Maryland with budgets under $20,000. No commitment required."
  canonical="https://baltimoreweddingplanner.com/contact"
>
  <div class="container">
    <Breadcrumbs items={[{ label: 'Contact & Booking' }]} />
  </div>

  <section class="section bg-[#FAF1EE]">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

        <!-- Left: Info -->
        <div>
          <h1 class="font-display text-4xl md:text-5xl font-medium text-stone-900 mb-5 leading-[1.15] tracking-tight">
            Book a Free Wedding Planning Consultation
          </h1>
          <p class="text-charcoal-muted text-lg leading-relaxed mb-6">
            Fill out the form and John will respond within 24 hours to schedule your free 30-minute consultation.
            No pressure. No commitment. Just clarity on your vision and what it'll cost.
          </p>

          <div class="bg-white border border-rose-light/40 rounded-lg p-5 mb-8">
            <p class="font-display text-sm font-bold text-charcoal mb-3">What happens on the call</p>
            <ul class="space-y-2">
              {[
                "John asks about your vision, guest count, and wedding date",
                "You tell him how much you've already planned and what's still up in the air",
                "He recommends the right package and gives you a real quote",
                "You decide if it's a fit : there's no obligation to book",
              ].map((step) => (
                <li class="flex items-start gap-2.5 text-sm text-charcoal-muted font-body">
                  <svg class="w-4 h-4 text-rose flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  {step}
                </li>
              ))}
            </ul>
          </div>

          <div class="space-y-5 mb-10">
            {[
              { label: 'Email', value: 'john@baltimoreweddingplanner.com', href: 'mailto:john@baltimoreweddingplanner.com' },
              { label: 'Phone', value: '(410) 555-0100', href: 'tel:+14105550100' },
              { label: 'Service Area', value: 'All of Maryland', href: null },
            ].map((item) => (
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-rose-50 rounded-lg flex items-center justify-center flex-shrink-0">
                  <div class="w-2.5 h-2.5 rounded-full bg-rose" />
                </div>
                <div>
                  <p class="text-xs text-charcoal-muted font-body uppercase tracking-wider">{item.label}</p>
                  {item.href ? (
                    <a href={item.href} class="font-display font-semibold text-charcoal hover:text-rose transition-colors">{item.value}</a>
                  ) : (
                    <p class="font-display font-semibold text-charcoal">{item.value}</p>
                  )}
                </div>
              </div>
            ))}
          </div>

          <!-- Calendly embed placeholder -->
          <div class="bg-white border border-rose-light/40 rounded-lg p-6">
            <h2 class="font-display text-lg font-bold text-charcoal mb-3">Or Book Directly on Calendly</h2>
            <p class="text-sm text-charcoal-muted font-body mb-4">Pick a time that works for you : 30-minute consultation calls available Monday-Saturday.</p>
            <!-- Replace YOURCALENDLYLINK with your actual Calendly URL -->
            <a
              href="https://calendly.com/YOURCALENDLYLINK"
              target="_blank"
              rel="noopener noreferrer"
              class="btn-primary w-full justify-center"
            >
              Pick a Time on Calendly
            </a>
          </div>
        </div>

        <!-- Right: Contact Form -->
        <div class="bg-white border border-rose-light/40 rounded-lg p-8">
          <h2 class="font-display text-2xl font-semibold text-stone-900 mb-6">Send John a Message</h2>

          <form
            name="consultation-request"
            method="POST"
            action="/thank-you"
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="space-y-5"
            novalidate
          >
            <input type="hidden" name="form-name" value="consultation-request" />
            <input type="hidden" name="bot-field" class="sr-only" aria-hidden="true" />

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="first-name" class="block text-sm font-medium font-body text-charcoal mb-1.5">
                  First Name <span class="text-rose" aria-label="required">*</span>
                </label>
                <input
                  type="text"
                  id="first-name"
                  name="first-name"
                  required
                  autocomplete="given-name"
                  class="w-full px-4 py-2.5 border border-rose-light/60 rounded text-sm font-body text-charcoal bg-white focus:outline-none focus:ring-2 focus:ring-rose focus:border-rose transition-colors placeholder:text-charcoal-muted/50"
                  placeholder="Sarah"
                />
              </div>
              <div>
                <label for="last-name" class="block text-sm font-medium font-body text-charcoal mb-1.5">
                  Last Name <span class="text-rose" aria-label="required">*</span>
                </label>
                <input
                  type="text"
                  id="last-name"
                  name="last-name"
                  required
                  autocomplete="family-name"
                  class="w-full px-4 py-2.5 border border-rose-light/60 rounded text-sm font-body text-charcoal bg-white focus:outline-none focus:ring-2 focus:ring-rose focus:border-rose transition-colors placeholder:text-charcoal-muted/50"
                  placeholder="Johnson"
                />
              </div>
            </div>

            <div>
              <label for="email" class="block text-sm font-medium font-body text-charcoal mb-1.5">
                Email Address <span class="text-rose" aria-label="required">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                class="w-full px-4 py-2.5 border border-rose-light/60 rounded text-sm font-body text-charcoal bg-white focus:outline-none focus:ring-2 focus:ring-rose focus:border-rose transition-colors placeholder:text-charcoal-muted/50"
                placeholder="sarah@email.com"
              />
            </div>

            <div>
              <label for="phone" class="block text-sm font-medium font-body text-charcoal mb-1.5">
                Phone Number
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                autocomplete="tel"
                class="w-full px-4 py-2.5 border border-rose-light/60 rounded text-sm font-body text-charcoal bg-white focus:outline-none focus:ring-2 focus:ring-rose focus:border-rose transition-colors placeholder:text-charcoal-muted/50"
                placeholder="(410) 555-0123"
              />
            </div>

            <div>
              <label for="wedding-date" class="block text-sm font-medium font-body text-charcoal mb-1.5">
                Wedding Date (or estimated)
              </label>
              <input
                type="date"
                id="wedding-date"
                name="wedding-date"
                class="w-full px-4 py-2.5 border border-rose-light/60 rounded text-sm font-body text-charcoal bg-white focus:outline-none focus:ring-2 focus:ring-rose focus:border-rose transition-colors"
              />
            </div>

            <div>
              <label for="budget" class="block text-sm font-medium font-body text-charcoal mb-1.5">
                Approximate Wedding Budget <span class="text-rose" aria-label="required">*</span>
              </label>
              <select
                id="budget"
                name="budget"
                required
                class="w-full px-4 py-2.5 border border-rose-light/60 rounded text-sm font-body text-charcoal bg-white focus:outline-none focus:ring-2 focus:ring-rose focus:border-rose transition-colors"
              >
                <option value="" disabled selected>Select your budget range</option>
                <option value="under-5k">Under $5,000 (Elopement)</option>
                <option value="5k-10k">$5,000 – $10,000</option>
                <option value="10k-15k">$10,000 – $15,000</option>
                <option value="15k-20k">$15,000 – $20,000</option>
                <option value="over-20k">Over $20,000</option>
              </select>
            </div>

            <div>
              <label for="service" class="block text-sm font-medium font-body text-charcoal mb-1.5">
                Service You're Interested In
              </label>
              <select
                id="service"
                name="service"
                class="w-full px-4 py-2.5 border border-rose-light/60 rounded text-sm font-body text-charcoal bg-white focus:outline-none focus:ring-2 focus:ring-rose focus:border-rose transition-colors"
              >
                <option value="" disabled selected>Select a service</option>
                <option value="elopement">Elopement / Micro-Wedding</option>
                <option value="day-of">Day-of Coordination</option>
                <option value="partial">Partial Planning</option>
                <option value="full-service">Full-Service Planning</option>
                <option value="not-sure">Not sure yet</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium font-body text-charcoal mb-1.5">
                Tell John About Your Vision
              </label>
              <textarea
                id="message"
                name="message"
                rows="4"
                class="w-full px-4 py-2.5 border border-rose-light/60 rounded text-sm font-body text-charcoal bg-white focus:outline-none focus:ring-2 focus:ring-rose focus:border-rose transition-colors placeholder:text-charcoal-muted/50 resize-none"
                placeholder="Where are you thinking for the venue? Indoor, outdoor, historic? Any vendors already booked?"
              ></textarea>
            </div>

            <button type="submit" class="btn-primary w-full justify-center text-base py-3.5">
              Send My Message
            </button>

            <p class="text-xs text-charcoal-muted font-body text-center">
              John responds within 24 hours. No spam, no sales pressure.
            </p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Internal links section -->
  <section class="section-sm bg-[#FAF1EE]">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 max-w-4xl mx-auto">
        <a href="/wedding-planning-packages" class="card p-5 hover:shadow-md hover:border-rose/30 transition-all group text-center">
          <h3 class="font-display text-sm font-semibold text-charcoal group-hover:text-rose transition-colors">View All Packages</h3>
          <p class="text-xs text-charcoal-muted font-body mt-1">From $300 to $2,800</p>
        </a>
        <a href="/services/day-of-wedding-coordinator" class="card p-5 hover:shadow-md hover:border-rose/30 transition-all group text-center">
          <h3 class="font-display text-sm font-semibold text-charcoal group-hover:text-rose transition-colors">Day-of Coordination</h3>
          <p class="text-xs text-charcoal-muted font-body mt-1">Most popular service</p>
        </a>
        <a href="/faq" class="card p-5 hover:shadow-md hover:border-rose/30 transition-all group text-center">
          <h3 class="font-display text-sm font-semibold text-charcoal group-hover:text-rose transition-colors">Read the FAQ</h3>
          <p class="text-xs text-charcoal-muted font-body mt-1">Common questions answered</p>
        </a>
      </div>
    </div>
  </section>
</Layout>
