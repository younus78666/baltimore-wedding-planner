---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const locations = [
  { city: 'Annapolis', slug: 'annapolis-wedding-planner', county: 'Anne Arundel County', desc: 'Waterfront venues, historic downtown, Chesapeake Bay settings.' },
  { city: 'Columbia', slug: 'columbia-md-wedding-planner', county: 'Howard County', desc: 'Modern venues, lakeside settings, convenient to Baltimore and DC.' },
  { city: 'Towson', slug: 'towson-wedding-planner', county: 'Baltimore County', desc: 'Suburban Baltimore venues, parks, and estate properties.' },
  { city: 'Frederick', slug: 'frederick-wedding-planner', county: 'Frederick County', desc: 'Historic downtown, mountain backdrops, vineyard and farm venues.' },
  { city: 'Rockville', slug: 'rockville-wedding-planner', county: 'Montgomery County', desc: 'DMV-area venues, suburban Maryland, close to DC couples.' },
];
---

<Layout
  title="Maryland Wedding Planner Service Areas | All of Maryland"
  description="John serves all of Maryland: Annapolis, Columbia, Towson, Frederick, and Rockville. Budget-friendly wedding planning and coordination. Free consultation."
  canonical="https://baltimoreweddingplanner.com/locations"
>
  <div class="container">
    <Breadcrumbs items={[{ label: 'Service Areas' }]} />
  </div>

  <section class="section-sm bg-[#FAF1EE]">
    <div class="container text-center max-w-2xl mx-auto">
      <h1 class="section-heading mb-4">Maryland Wedding Planner Service Areas</h1>
      <p class="section-sub">John serves couples across all of Maryland, from Baltimore City through the Eastern Shore, Western Maryland, and the DC suburbs.</p>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {locations.map((loc) => (
          <a href={`/locations/${loc.slug}`} class="card p-6 hover:shadow-md hover:border-rose/30 transition-all group">
            <span class="badge-rose mb-3 block w-fit">{loc.county}</span>
            <h2 class="font-display text-xl font-bold text-charcoal mb-2 group-hover:text-rose transition-colors">{loc.city}, MD</h2>
            <p class="text-sm text-charcoal-muted font-body leading-relaxed mb-4">{loc.desc}</p>
            <span class="text-sm font-semibold font-body text-rose inline-flex items-center gap-1.5">
              {loc.city} Wedding Planner
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </a>
        ))}
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mt-8 mb-10">
        <a href="/wedding-planning-packages" class="card p-5 hover:shadow-md hover:border-rose/30 transition-all group text-center">
          <h3 class="font-display text-sm font-semibold text-charcoal group-hover:text-rose transition-colors">View All Packages</h3>
          <p class="text-xs text-charcoal-muted font-body mt-1">From $300</p>
        </a>
        <a href="/services/day-of-wedding-coordinator" class="card p-5 hover:shadow-md hover:border-rose/30 transition-all group text-center">
          <h3 class="font-display text-sm font-semibold text-charcoal group-hover:text-rose transition-colors">Day-of Coordination</h3>
          <p class="text-xs text-charcoal-muted font-body mt-1">Most popular service</p>
        </a>
        <a href="/blog/wedding-venues-in-maryland" class="card p-5 hover:shadow-md hover:border-rose/30 transition-all group text-center">
          <h3 class="font-display text-sm font-semibold text-charcoal group-hover:text-rose transition-colors">Maryland Venues Guide</h3>
          <p class="text-xs text-charcoal-muted font-body mt-1">25+ venues statewide</p>
        </a>
      </div>

      <div class="bg-[#C89481] rounded-2xl p-10 text-center">
        <h2 class="font-display text-3xl font-bold text-white mb-4">Don't See Your City?</h2>
        <p class="text-white/80 font-body mb-8 max-w-xl mx-auto">John serves all of Maryland. If your city isn't listed, reach out. He likely covers your area and can confirm availability.</p>
        <a href="/contact" class="btn-white text-base px-8 py-4">Contact John</a>
      </div>
    </div>
  </section>
</Layout>
