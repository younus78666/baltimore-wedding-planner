---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Message Received | Baltimore Wedding Planner"
  description="Thank you for reaching out. John will respond within 24 hours."
  canonical="https://baltimoreweddingplanner.com/thank-you"
  noindex={true}
>
  <section class="section bg-[#FAF1EE] min-h-[60vh] flex items-center">
    <div class="container text-center max-w-xl mx-auto">
      <div class="w-20 h-20 bg-rose-50 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="w-10 h-10 text-rose" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h1 class="font-display text-4xl font-bold text-charcoal mb-4">Message Received!</h1>
      <p class="text-charcoal-muted text-lg font-body leading-relaxed mb-8">
        Thank you for reaching out to John. He'll respond within 24 hours to schedule your free consultation.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="btn-primary">Back to Homepage</a>
        <a href="/blog" class="btn-outline">Browse Wedding Resources</a>
      </div>
    </div>
  </section>
</Layout>
